generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
  binaryTargets   = ["native", "windows"]
}
datasource db {
  provider = "postgresql"
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum WorkspaceRole {
  ADMIN
  OWNER
  MEMBER
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ListColorPreset {
  GREEN
  YELLOW
  ORANGE
  RED
  PURPLE
  BLUE
  TEAL
  OLIVE
  BROWN
  GRAY
}

model User {
  id              Int       @default(autoincrement()) @id
  email           String    @unique
  passwordHash    String?   @map("password")
  name            String
  avatarPath      String?   @map("picture")
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  authTokens            AuthToken[]
  workspaceMembers      WorkspaceMember[]
  workspaceInvitesSent  WorkspaceInvite[]
}

model AuthToken {
  id Int @default(autoincrement()) @id
  userId Int
  type   AuthTokenType
  tokenHash String @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          Int       @default(autoincrement()) @id
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members WorkspaceMember[]
  invites WorkspaceInvite[]
  boards Board[]
}

model WorkspaceMember {
  id          Int           @default(autoincrement()) @id
  workspaceId Int
  userId      Int
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model WorkspaceInvite {
  id              Int           @default(autoincrement()) @id
  email           String
  workspaceId     Int
  invitedByUserId Int
  tokenHash       String?        @unique
  role            WorkspaceRole @default(MEMBER)
  status          WorkspaceInviteStatus @default(PENDING)
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, email])
}

model Board {
  id              Int           @default(autoincrement()) @id
  workspaceId Int
  name        String
  description String?
  position    Int      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  list List[]


}

model List {
  id              Int           @default(autoincrement()) @id
  boardId Int
  name        String
  position    Int      @default(0)
  colorPreset ListColorPreset  @default(GRAY)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

}




